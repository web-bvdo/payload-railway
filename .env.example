# Copy this file to .env and fill it in.  Tip: `npm run setup` does this for you
# and generates a PAYLOAD_SECRET automatically.

# --- Database ---
# Local dev: SQLite file (no server needed).
DATABASE_URI=file:./payload.db
# Railway/persistent host: point at the volume so the DB survives redeploys.
#   DATABASE_URI=file:/data/payload.db
# Production (Vercel): a hosted libSQL/Turso database. Set both in the Vercel
# dashboard (not here). See docs/DEPLOY-VERCEL.md.
#   DATABASE_URI=libsql://<db>-<org>.turso.io
#   DATABASE_AUTH_TOKEN=<turso token>
# The Vercel Turso integration injects TURSO_DATABASE_URL / TURSO_AUTH_TOKEN
# instead — the config reads those too, so you can skip the two above then.

# --- Media storage ---
# Local + persistent hosts (Railway/Render/VPS): files go to this folder on disk.
# On a host with a volume, point this at the mounted path so uploads survive
# redeploys (e.g. MEDIA_DIR=/data/media). Defaults to ./media.
#   MEDIA_DIR=/data/media
#
# Serverless (Vercel) only: no writable disk — uploads go to Vercel Blob when
# this token is present (the Blob store injects it). See docs/DEPLOY-VERCEL.md.
#   BLOB_READ_WRITE_TOKEN=<vercel blob token>

# --- Payload secret ---
# MUST be unique per site. Never reuse across client sites. Keep it out of git.
# Generate one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
PAYLOAD_SECRET=CHANGE_ME

# --- First admin user (used by `npm run seed`) ---
# Unique per site. Change the password after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
