# Copy this file to .env and fill it in.  Tip: `npm run setup` does this for you
# and generates a PAYLOAD_SECRET automatically.

# --- Database (Postgres) ---
# Local development: point this at a LOCAL Postgres. In dev mode Payload pushes
# the schema automatically. See docs/DEVELOPING.md.
#   docker run --name pg -e POSTGRES_PASSWORD=pw -p 5432:5432 -d postgres:16
DATABASE_URI=postgresql://postgres:pw@localhost:5432/postgres
# ⚠️ Never point this at a Railway database: dev mode would push the schema and
# then break that environment's `payload migrate` on deploy. Railway = migrations
# only; local = your own database.
# On Railway itself you don't set this — the Postgres service injects DATABASE_URL
# and the config reads that.

# --- Media storage ---
# Production: an S3-compatible bucket (Railway Bucket / Cloudflare R2). Uploads
# in the admin persist and are shared across dev/prod. On Railway these come
# from the Bucket service; set them in the dashboard, not here.
#   S3_BUCKET=<bucket name>
#   S3_ENDPOINT=<https://...>
#   S3_REGION=auto
#   S3_ACCESS_KEY_ID=<key>
#   S3_SECRET_ACCESS_KEY=<secret>
# Local dev: leave S3_BUCKET unset → uploads fall back to ./media on disk.
# (MEDIA_DIR overrides the local folder if you ever need to.)

# --- Payload secret ---
# MUST be unique per site. Never reuse across client sites. Keep it out of git.
# Generate one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
PAYLOAD_SECRET=CHANGE_ME

# --- First admin user (used by `npm run seed`) ---
# Unique per site. Change the password after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
