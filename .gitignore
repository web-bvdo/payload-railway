# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# next.js
/.next/
/out/
/build
next-env.d.ts
*.tsbuildinfo

# env (secrets — never commit). Ignore every .env* except the example.
.env
.env.*
!.env.example

# database (per-site, generated locally) — never commit: it holds the users
# table (admin emails + password hashes). Content goes in seed/content.json.
payload.db
payload.db-*

# NB: /media is intentionally NOT ignored — uploads are public site assets and
# ship with the repo (see docs/DEPLOY-RAILWAY.md). If you host media on a volume
# instead, add /media back here.

# misc
.DS_Store
*.pem
npm-debug.log*

# editors
/.idea/*
!/.idea/runConfigurations

# vercel
.vercel
